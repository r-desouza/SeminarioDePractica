<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gestionreposteria.controlador.AgendaController">
    
    <Label text="Agenda de Entregas Activas" style="-fx-font-size: 22; -fx-font-weight: bold;" />

    <TableView fx:id="tablaAgenda" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="Nº" prefWidth="50">
                <cellValueFactory><javafx.scene.control.cell.PropertyValueFactory property="idPedido" /></cellValueFactory>
            </TableColumn>
            <TableColumn text="Fecha" prefWidth="100">
                <cellValueFactory><javafx.scene.control.cell.PropertyValueFactory property="fecha" /></cellValueFactory>
            </TableColumn>
            <TableColumn text="Hora" prefWidth="80">
                <cellValueFactory><javafx.scene.control.cell.PropertyValueFactory property="hora" /></cellValueFactory>
            </TableColumn>
            <TableColumn text="Observaciones" prefWidth="350">
                <cellValueFactory><javafx.scene.control.cell.PropertyValueFactory property="observaciones" /></cellValueFactory>
            </TableColumn>
            <TableColumn text="Total" prefWidth="100">
                <cellValueFactory><javafx.scene.control.cell.PropertyValueFactory property="total" /></cellValueFactory>
            </TableColumn>
            <TableColumn text="Estado" prefWidth="120">
                <cellValueFactory><javafx.scene.control.cell.PropertyValueFactory property="estado" /></cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>

    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
        <Label text="Modificar estado del pedido seleccionado:" style="-fx-font-size: 14;" />
        <ComboBox fx:id="cbEstado" promptText="Nuevo Estado..." prefWidth="150" />
        <Button text="Actualizar" onAction="#actualizarEstado" style="-fx-background-color: #0dcaf0; -fx-text-fill: black; -fx-font-weight: bold;" />
    </HBox>

</VBox>